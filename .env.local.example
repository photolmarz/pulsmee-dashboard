# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# Supabase — Project Settings → API → service_role (JAMAIS exposée côté client)
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY

# Shopify — récupéré lors de la création du webhook
SHOPIFY_WEBHOOK_SECRET=VOTRE_WEBHOOK_SECRET
